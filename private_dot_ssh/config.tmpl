ForwardAgent yes
HashKnownHosts no

{{- if .private }}
Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_rsa
{{- end -}}

{{- if .work }}
StrictHostKeyChecking no
ForwardX11 no
ForwardX11Trusted no
ConnectTimeout 5
Compression yes
AddKeysToAgent yes
User {{ .user_name }}
NoHostAuthenticationForLocalhost no

{{- if stat "/etc/ssh/ssh_known_hosts" }}
GlobalKnownHostsFile /etc/ssh/ssh_known_hosts
{{- end }}

{{- $provider := "/usr/lib/ssh-keychain.dylib" -}}
{{- if eq .chezmoi.os "linux" }}
{{- $provider =  "/usr/lib/opensc-pkcs11.so" -}}
{{- end -}}

{{ range .jump_hosts }}
Host {{ . }}
    UpdateHostkeys yes
    PKCS11Provider {{ $provider }}

Host {{ . }}.{{ $.network.domain }}
    UpdateHostkeys yes
    PKCS11Provider {{ $provider }}
{{ end }}

Host github.com
    Hostname ssh.github.com
    Port 443
    User git
    ProxyCommand nc -X connect -x localhost:9999 %h %p
{{- end }}
